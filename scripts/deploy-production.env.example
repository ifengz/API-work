# API-work 自动部署环境模板
# 只放服务器本地，真实值不要提交到 GitHub。

APP_ROOT=/www/wwwroot/API-work
BRANCH=main
GIT_REMOTE=origin

DOCKER_COMPOSE_FILE=docker-compose.yml
ENV_FILE=.env
VERTEX_SOURCE_DIR=vertex
VERTEX_POOL_FILE=config/vertex-pool.json
VERTEX_CREDENTIALS_DIR=credentials/imported
VERTEX_PROJECTS=
VERTEX_PROJECTS_FILE=config/vertex-projects.allowlist
VERTEX_MAX_PER_PROJECT=
VERTEX_LOCATION=global
VERTEX_MODELS=
LITELLM_OUTPUT_FILE=config/litellm.generated.yaml

HEALTHCHECK_URL=http://127.0.0.1:8080/healthz
PUBLIC_URL=
HEALTHCHECK_ATTEMPTS=10
HEALTHCHECK_INTERVAL=3

PYTHON_BIN=python3
REQUIRE_ROOT=0

# 调试时可临时打开，正式部署建议保持 0，工作区脏了就直接失败。
ALLOW_DIRTY=0
