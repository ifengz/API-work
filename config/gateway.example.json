{
  "listen_host": "0.0.0.0",
  "listen_port": 8080,
  "upstreams": {
    "one_api": {
      "base_url": "http://one-api:3000",
      "api_key_env": "ONE_API_MASTER_TOKEN",
      "timeout_seconds": 120,
      "chat_path": "/v1/chat/completions",
      "image_path": "/v1/images/generations"
    },
    "litellm": {
      "base_url": "http://litellm:4000",
      "api_key_env": "LITELLM_MASTER_KEY",
      "timeout_seconds": 120,
      "chat_path": "/v1/chat/completions",
      "image_path": "/v1/images/generations"
    }
  },
  "model_routes": {
    "gemini-3-flash-preview": {
      "upstream": "litellm",
      "upstream_model": "gemini-3-flash-preview",
      "multimodal_chat_upstream": "one_api"
    },
    "gemini-3.1-pro-preview": {
      "upstream": "litellm",
      "upstream_model": "gemini-3.1-pro-preview",
      "multimodal_chat_upstream": "one_api"
    },
    "gemini-3.1-flash-lite-preview": {
      "upstream": "litellm",
      "upstream_model": "gemini-3.1-flash-lite-preview",
      "multimodal_chat_upstream": "one_api"
    },
    "gemini-3-pro-image-preview": {
      "upstream": "litellm",
      "upstream_model": "gemini-3-pro-image-preview"
    },
    "gemini-3.1-flash-image-preview": {
      "upstream": "litellm",
      "upstream_model": "gemini-3.1-flash-image-preview"
    },
    "gemini-2.5-flash": {
      "upstream": "litellm",
      "upstream_model": "gemini-2.5-flash",
      "multimodal_chat_upstream": "one_api"
    },
    "gemini-2.5-pro": {
      "upstream": "litellm",
      "upstream_model": "gemini-2.5-pro",
      "multimodal_chat_upstream": "one_api"
    },
    "gemini-2.5-flash-image": {
      "upstream": "litellm",
      "upstream_model": "gemini-2.5-flash-image"
    },
    "gpt-4o-mini": {
      "upstream": "one_api",
      "upstream_model": "gpt-4o-mini"
    },
    "claude-3-7-sonnet": {
      "upstream": "one_api",
      "upstream_model": "claude-3-7-sonnet"
    },
    "deepseek-chat": {
      "upstream": "one_api",
      "upstream_model": "deepseek-chat"
    },
    "qwen-max": {
      "upstream": "one_api",
      "upstream_model": "qwen-max"
    },
    "glm-4.5": {
      "upstream": "one_api",
      "upstream_model": "glm-4.5"
    },
    "minimax-text-01": {
      "upstream": "one_api",
      "upstream_model": "minimax-text-01"
    },
    "moonshot-v1-32k": {
      "upstream": "one_api",
      "upstream_model": "moonshot-v1-32k"
    }
  },
  "sites": [
    {
      "site_token": "site-demo-a",
      "name": "demo-a",
      "allowed_origins": [
        "https://image.usfan.net",
        "http://127.0.0.1:5173",
        "http://localhost:5173"
      ],
      "allowed_models": [
        "gemini-3-flash-preview",
        "gemini-3.1-pro-preview",
        "gemini-3.1-flash-lite-preview",
        "gemini-3-pro-image-preview",
        "gemini-3.1-flash-image-preview",
        "gemini-2.5-pro",
        "gemini-2.5-flash",
        "gemini-2.5-flash-image",
        "gpt-4o-mini",
        "claude-3-7-sonnet",
        "deepseek-chat"
      ],
      "default_chat_model": "gemini-3-flash-preview",
      "default_image_model": "gemini-3-pro-image-preview",
      "chat_model_candidates": [
        "gemini-3-flash-preview",
        "gemini-3.1-pro-preview",
        "gemini-3.1-flash-lite-preview",
        "gemini-2.5-pro",
        "gemini-2.5-flash"
      ],
      "image_model_candidates": [
        "gemini-3-pro-image-preview",
        "gemini-3.1-flash-image-preview",
        "gemini-2.5-flash-image"
      ],
      "extra_headers": {
        "X-Site-Group": "demo-a"
      }
    },
    {
      "site_token": "site-demo-b",
      "name": "demo-b",
      "allowed_origins": [
        "https://image.usfan.net",
        "http://127.0.0.1:5173",
        "http://localhost:5173"
      ],
      "allowed_models": [
        "gemini-3-flash-preview",
        "gemini-3.1-pro-preview",
        "gemini-3.1-flash-lite-preview",
        "gemini-3-pro-image-preview",
        "gemini-3.1-flash-image-preview",
        "gemini-2.5-pro",
        "gemini-2.5-flash",
        "gemini-2.5-flash-image",
        "qwen-max",
        "glm-4.5",
        "moonshot-v1-32k"
      ],
      "default_chat_model": "gemini-3-flash-preview",
      "default_image_model": "gemini-3-pro-image-preview",
      "chat_model_candidates": [
        "gemini-3-flash-preview",
        "gemini-3.1-pro-preview",
        "gemini-3.1-flash-lite-preview",
        "gemini-2.5-pro",
        "gemini-2.5-flash"
      ],
      "image_model_candidates": [
        "gemini-3-pro-image-preview",
        "gemini-3.1-flash-image-preview",
        "gemini-2.5-flash-image"
      ],
      "extra_headers": {
        "X-Site-Group": "demo-b"
      }
    }
  ]
}
