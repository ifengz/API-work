{
  "master_key_env": "LITELLM_MASTER_KEY",
  "salt_key_env": "LITELLM_SALT_KEY",
  "router": {
    "routing_strategy": "simple-shuffle",
    "num_retries": 2,
    "timeout": 120,
    "fallbacks": {
      "vertex-gemini-pro": [
        "vertex-gemini-flash"
      ]
    }
  },
  "deployments": [
    {
      "alias": "vertex-gemini-flash",
      "provider_model": "vertex_ai/gemini-2.5-flash",
      "project_env": "VERTEX_PRIMARY_PROJECT",
      "location_env": "VERTEX_PRIMARY_LOCATION",
      "credentials_file": "/app/credentials/vertex-primary.json",
      "rpm": 120
    },
    {
      "alias": "vertex-gemini-flash",
      "provider_model": "vertex_ai/gemini-2.5-flash",
      "project_env": "VERTEX_SECONDARY_PROJECT",
      "location_env": "VERTEX_SECONDARY_LOCATION",
      "credentials_file": "/app/credentials/vertex-secondary.json",
      "rpm": 120
    },
    {
      "alias": "vertex-gemini-pro",
      "provider_model": "vertex_ai/gemini-2.5-pro",
      "project_env": "VERTEX_PRIMARY_PROJECT",
      "location_env": "VERTEX_PRIMARY_LOCATION",
      "credentials_file": "/app/credentials/vertex-primary.json",
      "rpm": 60
    },
    {
      "alias": "vertex-imagen-3",
      "provider_model": "vertex_ai/imagen-3.0-generate-002",
      "project_env": "VERTEX_PRIMARY_PROJECT",
      "location_env": "VERTEX_PRIMARY_LOCATION",
      "credentials_file": "/app/credentials/vertex-primary.json",
      "rpm": 30
    }
  ]
}

