{
  "master_key_env": "LITELLM_MASTER_KEY",
  "salt_key_env": "LITELLM_SALT_KEY",
  "router": {
    "routing_strategy": "simple-shuffle",
    "num_retries": 2,
    "timeout": 120,
    "fallbacks": {
      "gemini-2.5-pro": [
        "gemini-2.5-flash"
      ]
    }
  },
  "deployments": [
    {
      "alias": "gemini-2.5-flash",
      "provider_model": "vertex_ai/gemini-2.5-flash",
      "project_env": "VERTEX_PRIMARY_PROJECT",
      "location_env": "VERTEX_PRIMARY_LOCATION",
      "credentials_file": "/app/credentials/vertex-primary.json",
      "rpm": 120
    },
    {
      "alias": "gemini-2.5-pro",
      "provider_model": "vertex_ai/gemini-2.5-pro",
      "project_env": "VERTEX_PRIMARY_PROJECT",
      "location_env": "VERTEX_PRIMARY_LOCATION",
      "credentials_file": "/app/credentials/vertex-primary.json",
      "rpm": 60
    },
    {
      "alias": "gemini-2.5-flash-image",
      "provider_model": "vertex_ai/gemini-2.5-flash-image",
      "project_env": "VERTEX_PRIMARY_PROJECT",
      "location_env": "VERTEX_PRIMARY_LOCATION",
      "credentials_file": "/app/credentials/vertex-primary.json",
      "rpm": 30
    }
  ]
}
