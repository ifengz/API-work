TZ=Asia/Shanghai

# site-gateway
SITE_GATEWAY_CONFIG=/app/config/gateway.json
SITE_GATEWAY_AUDIT_DB=/data/site-gateway/audit.db

# one-api
ONE_API_ROOT_TOKEN=replace-with-root-token
ONE_API_ROOT_ACCESS_TOKEN=replace-with-root-access-token
ONE_API_SESSION_SECRET=replace-with-session-secret
ONE_API_MASTER_TOKEN=replace-with-upstream-token-for-site-gateway

# LiteLLM
LITELLM_MASTER_KEY=replace-with-litellm-master-key
LITELLM_SALT_KEY=replace-with-litellm-salt-key

# Vertex primary pool
VERTEX_PRIMARY_PROJECT=replace-with-primary-project
VERTEX_PRIMARY_LOCATION=us-central1

# Vertex secondary pool
VERTEX_SECONDARY_PROJECT=replace-with-secondary-project
VERTEX_SECONDARY_LOCATION=us-central1
